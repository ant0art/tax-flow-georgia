# ⚠️ WARNING: All VITE_* variables are embedded into the JS bundle at build time.
# They are visible to anyone inspecting the application in a browser.
# Do NOT put truly secret values here — use server-side secrets instead.

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Create your own at https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# RS.GE Declaration Proxy (optional — declarations feature)
VITE_RSGE_WORKER_URL=https://your-worker.workers.dev
VITE_RSGE_API_KEY=your-api-key
